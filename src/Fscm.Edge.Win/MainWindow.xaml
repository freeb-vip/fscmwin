<Window
  x:Class="Fscm.Edge.Win.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="FSCM Edge"
  Width="1180"
  Height="760"
  MinWidth="980"
  MinHeight="640"
  Icon="Assets/fscm-edge.ico"
  WindowState="Maximized"
  WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F7FB" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0" />
    <SolidColorBrush x:Key="TextBrush" Color="#111827" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />

    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="StatusPillStyle" TargetType="Border">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
      <Setter Property="Margin" Value="10,3" />
      <Setter Property="Padding" Value="14,11" />
      <Setter Property="Foreground" Value="#334155" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border
              x:Name="ItemBorder"
              Background="Transparent"
              CornerRadius="8"
              Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF1FF" />
                <Setter Property="Foreground" Value="#1D4ED8" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Button">
      <Setter Property="MinWidth" Value="88" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#1E293B" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#2563EB" />
      <Setter Property="BorderBrush" Value="#2563EB" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#DC2626" />
      <Setter Property="BorderBrush" Value="#DC2626" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style x:Key="CopyCodeButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="TemplateTileActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="TemplateTilePrintButtonStyle" TargetType="Button" BasedOn="{StaticResource TemplateTileActionButtonStyle}">
      <Setter Property="Background" Value="#2563EB" />
      <Setter Property="BorderBrush" Value="#2563EB" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="CanUserDeleteRows" Value="False" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="RowHeight" Value="52" />
      <Setter Property="AlternationCount" Value="2" />
      <Setter Property="BorderBrush" Value="#E2E8F0" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Height" Value="44" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#334155" />
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#E2E8F0" />
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="DataGridRow">
      <Setter Property="Height" Value="52" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Style.Triggers>
        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
          <Setter Property="Background" Value="#F8FAFC" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#EFF6FF" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#DBEAFE" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Background="{StaticResource PageBackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border
      Grid.Column="0"
      Background="#FFFFFF"
      BorderBrush="#E2E8F0"
      BorderThickness="0,0,1,0">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Margin="22,24,22,18">
          <TextBlock
            FontSize="24"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
            Text="FSCM Edge" />
          <TextBlock
            Margin="0,6,0,0"
            Foreground="{StaticResource MutedTextBrush}"
            Text="本地边缘节点" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Margin="18" Padding="14" Background="#F8FAFC" CornerRadius="8">
          <StackPanel>
            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="本地地址" />
            <TextBlock
              x:Name="SidebarLanText"
              Margin="0,5,0,0"
              FontWeight="SemiBold"
              TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <ListBox
          x:Name="NavigationList"
          BorderThickness="0"
          ItemContainerStyle="{StaticResource NavItemStyle}"
          SelectionChanged="OnNavigationChanged"
          SelectedIndex="0">
          <ListBoxItem Tag="Home">总览</ListBoxItem>
          <ListBoxItem Tag="Products">产品管理</ListBoxItem>
          <ListBoxItem Tag="BoxLabels">箱唛管理</ListBoxItem>
          <ListBoxItem Tag="Terminals">在线终端</ListBoxItem>
          <ListBoxItem Tag="LabelPrint">标签打印</ListBoxItem>
          <ListBoxItem Tag="BatchPrint">批量打印</ListBoxItem>
          <ListBoxItem Tag="Print">打印任务</ListBoxItem>
          <ListBoxItem Tag="PrintConfig">打印配置</ListBoxItem>
          <ListBoxItem Tag="Advanced">高级设置</ListBoxItem>
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border
        Grid.Row="0"
        Background="#FFFFFF"
        BorderBrush="#E2E8F0"
        BorderThickness="0,0,0,1"
        Padding="28,20">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Left">
            <TextBlock
              x:Name="PageTitleText"
              FontSize="24"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
              Text="总览" />
            <TextBlock
              x:Name="PageSubtitleText"
              Margin="0,5,0,0"
              Foreground="{StaticResource MutedTextBrush}"
              Text="查看边缘节点最关键的运行状态。" />
          </StackPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Border
              x:Name="HeaderStatusPill"
              MinWidth="210"
              Margin="0,0,12,0"
              Padding="12,8"
              Background="#FEF3C7"
              BorderBrush="#F59E0B"
              BorderThickness="1"
              CornerRadius="6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Ellipse
                  x:Name="HeaderStatusDot"
                  Width="12"
                  Height="12"
                  Margin="0,0,10,0"
                  VerticalAlignment="Center"
                  Fill="#F59E0B" />
                <StackPanel Grid.Column="1">
                  <TextBlock
                    x:Name="HeaderStatusText"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#78350F"
                    Text="正在检查运行状态" />
                  <TextBlock
                    x:Name="HeaderStatusDetailText"
                    Margin="0,2,0,0"
                    FontSize="12"
                    Foreground="#92400E"
                    Text="正在检测本地服务" />
                </StackPanel>
              </Grid>
            </Border>
            <Button
              x:Name="RefreshButton"
              MinWidth="118"
              Click="OnRefreshClick"
              Style="{StaticResource PrimaryButtonStyle}"
              ToolTip="重新检测运行状态">
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  x:Name="RefreshIconText"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="15"
                  RenderTransformOrigin="0.5,0.5"
                  Text="&#xE72C;">
                  <TextBlock.RenderTransform>
                    <RotateTransform x:Name="RefreshIconRotation" />
                  </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="RefreshButtonText" VerticalAlignment="Center" Text="刷新状态" />
              </StackPanel>
            </Button>
          </StackPanel>
        </DockPanel>
      </Border>

      <Grid Grid.Row="1">
        <ScrollViewer x:Name="HomePage" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <UniformGrid Columns="3">
              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="本地服务" />
                  <Border x:Name="LocalStatusBadge" Style="{StaticResource StatusPillStyle}" Margin="0,12,0,10" Background="#FEF3C7">
                    <TextBlock x:Name="LocalStatusText" FontWeight="SemiBold" Foreground="#92400E" Text="检查中" />
                  </Border>
                  <TextBlock x:Name="LocalStatusMessageText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="远端服务" />
                  <Border x:Name="RemoteStatusBadge" Style="{StaticResource StatusPillStyle}" Margin="0,12,0,10" Background="#E2E8F0">
                    <TextBlock x:Name="RemoteStatusText" FontWeight="SemiBold" Foreground="#475569" Text="未配置" />
                  </Border>
                  <TextBlock x:Name="RemoteStatusMessageText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="节点注册" />
                  <Border x:Name="RegistrationStatusBadge" Style="{StaticResource StatusPillStyle}" Margin="0,12,0,10" Background="#E2E8F0">
                    <TextBlock x:Name="RegistrationStatusText" FontWeight="SemiBold" Foreground="#475569" Text="未注册" />
                  </Border>
                  <TextBlock x:Name="RegistrationMessageText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <UniformGrid Columns="4" Margin="0,0,0,14">
              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="连接终端" />
                  <TextBlock x:Name="HomeTerminalCountText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#0F766E" Text="0" />
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="已探测的局域网终端" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="打印排队" />
                  <TextBlock x:Name="HomePrintQueueText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#C2410C" Text="0" />
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="等待本机处理的任务" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="已处理打印" />
                  <TextBlock x:Name="HomePrintProcessedText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#2563EB" Text="0" />
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="当前本地任务记录" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="缓存效率" />
                  <TextBlock x:Name="HomeCacheHitRateText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#7C3AED" Text="--" />
                  <TextBlock x:Name="HomeCacheSizeText" Foreground="{StaticResource MutedTextBrush}" Text="等待缓存状态" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="局域网访问地址" />
                  <TextBlock x:Name="HomeLanText" Margin="0,6,18,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock x:Name="HomeWebLabelUrlText" Margin="0,8,18,0" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                  <Button Margin="0,10,18,0" HorizontalAlignment="Left" Click="OnCopyLabelPrintUrlClick" Content="复制 Web 打印地址" />
                  <Image x:Name="HomeWebLabelQrImage" Width="116" Height="116" Margin="0,14,18,0" Stretch="Uniform" ToolTip="扫描打开 Web 标签打印页面" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="边缘代理版本" />
                  <TextBlock x:Name="HomeVersionText" Margin="0,6,18,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="缓存策略" />
                  <TextBlock x:Name="HomeSyncedText" Margin="0,6,0,0" FontWeight="SemiBold" Text="标准" />
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="RemotePage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="远端服务器" />
                <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="配置 FSCM 中心服务地址，用于透明代理业务请求、节点注册和发现。" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="服务器地址" />
                <TextBox x:Name="CenterUrlTextBox" Margin="0,6,0,14" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="工作空间 ID" />
                <TextBox x:Name="NamespaceIdTextBox" Margin="0,6,0,14" />
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Node ID (stable identity)" />
                    <TextBox x:Name="NodeIdTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Node name (display)" />
                    <TextBox x:Name="NodeNameTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="LAN base URL override (optional)" />
                <TextBox x:Name="LanBaseUrlTextBox" Margin="0,6,0,14" ToolTip="Leave empty to select an active private LAN IPv4 automatically. Example: http://192.168.1.20:8089" />
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="API Token" />
                <PasswordBox x:Name="ApiTokenPasswordBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <TextBlock
                    x:Name="ApiTokenStatusText"
                    Grid.Column="1"
                    Margin="14,25,0,0"
                    Foreground="{StaticResource MutedTextBrush}"
                    VerticalAlignment="Top" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="RemoteDetailText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                  <Button x:Name="TestRemoteButton" Grid.Column="1" Margin="12,0,0,0" Click="OnTestRemoteClick" Content="测试连接" />
                  <Button Grid.Column="2" Margin="8,0,0,0" Click="OnSaveRemoteClick" Content="保存配置" Style="{StaticResource PrimaryButtonStyle}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="节点信息" />
                  <TextBlock x:Name="RemoteNodeNameText" Margin="0,14,0,0" />
                  <TextBlock x:Name="RemoteLanText" Margin="0,8,0,0" TextWrapping="Wrap" />
                  <TextBlock x:Name="RemoteCheckedText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="服务能力" />
                  <ItemsControl x:Name="CapabilitiesItems" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,8,8" Padding="10,5" Background="#EFF6FF" CornerRadius="12">
                          <TextBlock Foreground="#1D4ED8" Text="{Binding}" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                </StackPanel>
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="边缘代理缓存" />
                <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="缓存仅保存在内存中，重启后自动清空。配置修改后需重启边缘服务。" />
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="缓存模式" />
                    <ComboBox x:Name="CacheModeComboBox" Margin="0,6,0,0" Height="36" SelectedValuePath="Tag">
                      <ComboBoxItem Content="关闭" Tag="disabled" />
                      <ComboBoxItem Content="标准" Tag="standard" />
                      <ComboBoxItem Content="积极" Tag="aggressive" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="内存上限 (MB)" />
                    <TextBox x:Name="CacheMemoryTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="单项上限 (MB)" />
                    <TextBox x:Name="CacheObjectTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="3">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="过期兜底 (小时)" />
                    <TextBox x:Name="CacheStaleHoursTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>
                <DockPanel>
                  <TextBlock x:Name="CacheStatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="等待边缘服务状态" TextWrapping="Wrap" />
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Click="OnRefreshCacheClick" Content="刷新状态" />
                    <Button Margin="8,0,0,0" Click="OnClearCacheClick" Content="清空缓存" />
                  </StackPanel>
                </DockPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <Grid x:Name="TerminalsPage" Visibility="Collapsed" Margin="28">
          <Border Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="在线终端" />
                  <TextBlock Margin="0,6,0,4" Foreground="{StaticResource MutedTextBrush}" Text="已连接本地边缘节点的移动终端，可从这里发出寻找响铃。" />
                  <TextBlock x:Name="TerminalActionStatusText" Margin="0,0,0,14" Foreground="{StaticResource MutedTextBrush}" Text="等待终端连接" />
                </StackPanel>
                <Button DockPanel.Dock="Right" Click="OnRefreshTerminalsClick" Content="刷新终端" />
              </DockPanel>
              <DataGrid x:Name="TerminalsGrid" Grid.Row="1" ItemsSource="{Binding}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="终端名称" Binding="{Binding Name}" Width="170" />
                  <DataGridTextColumn Header="终端 ID" Binding="{Binding TerminalId}" Width="190" />
                  <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="140" />
                  <DataGridTextColumn Header="版本" Binding="{Binding AppVersion}" Width="90" />
                  <DataGridTextColumn Header="最后在线" Binding="{Binding LastSeenAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
                  <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80" />
                  <DataGridTemplateColumn Header="操作" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                          <Button Padding="10,4" Click="OnFindTerminalClick" Content="响铃" IsEnabled="{Binding CanStartFind}" ToolTip="让终端持续响铃 60 秒" />
                          <Button Margin="6,0,0,0" Padding="10,4" Click="OnStopFindingTerminalClick" Content="停止" IsEnabled="{Binding CanStopFind}" ToolTip="停止当前寻找响铃" />
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
        </Grid>

        <ScrollViewer x:Name="LabelPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="标签打印" />
                <TextBlock Margin="0,6,0,18" Foreground="{StaticResource MutedTextBrush}" Text="本机标签模板与打印机状态" />
                <DockPanel Margin="0,0,0,10">
                  <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Text="标签模板" />
                </DockPanel>
                <ComboBox x:Name="LabelTemplateComboBox" Visibility="Collapsed" DisplayMemberPath="DisplayName" SelectionChanged="OnLabelTemplateSelected" />
                <ItemsControl x:Name="LabelTemplateTiles" Margin="0,0,0,16">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Height="190" Margin="0,0,10,10" Padding="12" CornerRadius="8" Cursor="Hand" MouseLeftButtonUp="OnSelectLabelTemplateTileClick">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="#FFFFFF" />
                            <Setter Property="BorderBrush" Value="#CBD5E1" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSelectedForLabelPrint}" Value="True">
                                <Setter Property="Background" Value="#EFF6FF" />
                                <Setter Property="BorderBrush" Value="#2563EB" />
                                <Setter Property="BorderThickness" Value="2" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <Grid>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <DockPanel Grid.Row="0" LastChildFill="False">
                            <Border Width="30" Height="30" Background="#2563EB" CornerRadius="6">
                              <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#FFFFFF" Text="&#xE749;" />
                            </Border>
                            <Border DockPanel.Dock="Right" Padding="7,3" Background="#DBEAFE" CornerRadius="10">
                              <Border.Style>
                                <Style TargetType="Border">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedForLabelPrint}" Value="True">
                                      <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </Border.Style>
                              <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#1D4ED8" Text="当前" />
                            </Border>
                          </DockPanel>
                          <TextBlock Grid.Row="1" Margin="0,6,0,0" FontSize="13" FontWeight="Bold" MaxHeight="34" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" />
                          <TextBlock Grid.Row="2" Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Text="{Binding PaperDisplayText}" TextTrimming="CharacterEllipsis" />
                          <StackPanel Grid.Row="3" Margin="0,2,0,0">
                            <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}" Text="{Binding LayoutDisplayText}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Text="{Binding PrinterDisplayText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PrinterDisplayText}" />
                            <TextBlock Margin="0,2,0,0" FontSize="10" FontWeight="SemiBold" Text="{Binding PrinterStatusText}" TextTrimming="CharacterEllipsis">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Foreground" Value="#166534" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPrinterAvailable}" Value="False">
                                      <Setter Property="Foreground" Value="#991B1B" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </StackPanel>
                          <StackPanel Grid.Row="4" HorizontalAlignment="Right" Orientation="Horizontal">
                              <Button Margin="0,0,4,0" Click="OnPrintLabelTemplateTileClick" IsEnabled="{Binding IsPrinterAvailable}" Style="{StaticResource TemplateTilePrintButtonStyle}" ToolTip="使用此模板打印当前内容">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE749;" />
                              </Button>
                              <Button Margin="0,0,4,0" Click="OnPreviewLabelTemplateTileClick" Style="{StaticResource TemplateTileActionButtonStyle}" ToolTip="预览此模板">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE890;" />
                              </Button>
                              <Button Click="OnEditLabelTemplateTileClick" Style="{StaticResource TemplateTileActionButtonStyle}" ToolTip="编辑此模板">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE70F;" />
                              </Button>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <UniformGrid Margin="0,0,0,16" Columns="4">
                    <StackPanel Margin="0,0,10,0">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="打印机" />
                      <TextBlock x:Name="LabelPrinterText" Margin="0,5,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="纸张" />
                      <TextBlock x:Name="LabelPaperText" Margin="0,5,0,0" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="方向" />
                      <TextBlock x:Name="LabelOrientationText" Margin="0,5,0,0" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="二维码前缀" />
                      <TextBox x:Name="LabelPrefixTextBox" Margin="0,5,0,0" Height="32" MaxLength="20" ToolTip="标签二维码前缀；留空表示不添加前缀" />
                    </StackPanel>
                </UniformGrid>
                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="标签内容" />
                    <TextBox x:Name="LabelTextBox" Margin="0,6,0,0" Height="36" AcceptsReturn="False" TextWrapping="NoWrap" ToolTip="输入二维码和标签下方显示的字符串" />
                  </StackPanel>
                  <Border Grid.Column="1" Width="180" Height="120" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="14">
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="当前模板" />
                      <TextBlock x:Name="LabelTemplateSummaryText" Margin="0,5,0,0" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock x:Name="LabelModeText" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                  </Border>
                </Grid>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="LabelStatusText" Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Click="OnPreviewLabelClick" Content="预览标签" />
                    <Button x:Name="LabelPrintButton" Margin="8,0,0,0" Click="OnPrintLabelClick" Content="打印标签" Style="{StaticResource PrimaryButtonStyle}" />
                  </StackPanel>
                </DockPanel>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="BatchPrintPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <DockPanel Margin="0,0,0,18">
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="创建批量打印" />
                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="预览确认后提交中心队列，由当前边缘节点按批次顺序领取并打印。" />
                  </StackPanel>
                  <Button DockPanel.Dock="Right" Click="OnRefreshBatchPrintClick" Content="刷新" />
                </DockPanel>

                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="0.7*" />
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.05*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="边缘节点" />
                    <TextBlock x:Name="BatchNodeText" Margin="0,8,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="打印模板" />
                    <ComboBox x:Name="BatchTemplateComboBox" Margin="0,6,0,0" Height="36" DisplayMemberPath="DisplayName" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="默认份数（最多 5 份）" />
                    <TextBox x:Name="BatchCopiesTextBox" Margin="0,6,0,0" Height="36" Text="1" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="失败策略" />
                    <ComboBox x:Name="BatchFailurePolicyComboBox" Margin="0,6,0,0" Height="36" SelectedIndex="0" SelectedValuePath="Tag">
                      <ComboBoxItem Content="失败后暂停" Tag="pause" />
                      <ComboBoxItem Content="跳过失败继续" Tag="continue" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="4">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="内容来源" />
                    <ComboBox x:Name="BatchSourceComboBox" Margin="0,6,0,0" Height="36" SelectedIndex="0" SelectedValuePath="Tag" SelectionChanged="OnBatchSourceChanged">
                      <ComboBoxItem Content="范围生成" Tag="range" />
                      <ComboBoxItem Content="手工录入" Tag="manual" />
                      <ComboBoxItem Content="文件导入" Tag="upload" />
                    </ComboBox>
                  </StackPanel>
                </Grid>

                <Grid x:Name="BatchRangePanel" Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="0.5*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="开始内容" />
                    <TextBox x:Name="BatchRangeStartTextBox" Margin="0,6,0,0" Height="36" Text="H01-00-01" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="结束内容" />
                    <TextBox x:Name="BatchRangeEndTextBox" Margin="0,6,0,0" Height="36" Text="H01-00-15" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="步长" />
                    <TextBox x:Name="BatchRangeStepTextBox" Margin="0,6,0,0" Height="36" Text="1" />
                  </StackPanel>
                </Grid>

                <StackPanel x:Name="BatchManualPanel" Margin="0,0,0,16" Visibility="Collapsed">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="打印内容（每行一条；可使用 Tab 加份数，例如 H01-00-01    2）" />
                  <TextBox x:Name="BatchManualTextBox" Margin="0,6,0,0" MinHeight="130" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" />
                </StackPanel>

                <Grid x:Name="BatchUploadPanel" Margin="0,0,0,16" Visibility="Collapsed">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="CSV / Excel 文件" />
                    <TextBlock x:Name="BatchImportFileText" Margin="0,8,0,0" FontWeight="SemiBold" Text="尚未选择文件" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <Button Grid.Column="1" Margin="0,22,8,0" Click="OnDownloadBatchTemplateClick" Content="下载 CSV 模板" />
                  <Button Grid.Column="2" Margin="0,22,0,0" Click="OnImportBatchFileClick" Content="选择文件" Style="{StaticResource PrimaryButtonStyle}" />
                </Grid>

                <DockPanel>
                  <TextBlock x:Name="BatchPrintStatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="请选择配置并生成预览。" TextWrapping="Wrap" />
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BatchStopButton" Margin="0,0,8,0" Click="OnStopActiveBatchClick" Content="停止当前批次" IsEnabled="False" Style="{StaticResource DangerButtonStyle}" />
                    <Button x:Name="BatchPreviewButton" Click="OnPreviewBatchPrintClick" Content="生成预览" />
                    <Button x:Name="BatchSubmitButton" Margin="8,0,0,0" Click="OnSubmitBatchPrintClick" Content="提交整个批次" IsEnabled="False" Style="{StaticResource PrimaryButtonStyle}" />
                  </StackPanel>
                </DockPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <StackPanel>
                <DockPanel Margin="0,0,0,12">
                  <TextBlock DockPanel.Dock="Left" FontSize="18" FontWeight="SemiBold" Text="打印内容预览" />
                  <TextBlock x:Name="BatchPreviewSummaryText" DockPanel.Dock="Right" Foreground="{StaticResource MutedTextBrush}" Text="0 条" />
                </DockPanel>
                <DataGrid x:Name="BatchPreviewGrid" MinHeight="260" MaxHeight="420" IsReadOnly="True" CanUserAddRows="False">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="顺序" Binding="{Binding SequenceNo}" Width="70" />
                    <DataGridTextColumn Header="打印内容" Binding="{Binding Content}" Width="*" />
                    <DataGridTextColumn Header="份数" Binding="{Binding Copies}" Width="80" />
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="110" />
                    <DataGridTextColumn Header="校验状态" Binding="{Binding ValidationStatus}" Width="110" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="180" />
                  </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="BatchWarningsText" Margin="0,10,0,0" Foreground="#B45309" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="当前节点最近批次" />
                <DataGrid x:Name="BatchHistoryGrid" Margin="0,14,0,0" MinHeight="230" MaxHeight="420" IsReadOnly="True" CanUserAddRows="False">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="批次" Binding="{Binding Id}" Width="75" />
                    <DataGridTextColumn Header="模板" Binding="{Binding TemplateCode}" Width="170" />
                    <DataGridTextColumn Header="打印机" Binding="{Binding PrinterName}" Width="180" />
                    <DataGridTextColumn Header="进度" Binding="{Binding ProgressText}" Width="90" />
                    <DataGridTextColumn Header="执行方式" Binding="{Binding IntervalText}" Width="100" />
                    <DataGridTextColumn Header="失败策略" Binding="{Binding FailurePolicyText}" Width="120" />
                    <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="90" />
                    <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="165" />
                    <DataGridTemplateColumn Header="操作" Width="190">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal">
                            <Button Margin="0,0,5,0" Padding="7,2" Click="OnPauseBatchClick" Content="暂停" />
                            <Button Margin="0,0,5,0" Padding="7,2" Click="OnResumeBatchClick" Content="继续" />
                            <Button Padding="7,2" Click="OnCancelBatchClick" Content="停止" Style="{StaticResource DangerButtonStyle}" />
                          </StackPanel>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="PrintPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border x:Name="PrintJobsCard" Style="{StaticResource CardStyle}" MinHeight="420">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="打印任务" />
                    <TextBlock x:Name="PrintQueueSummaryText" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="正在加载打印任务..." />
                  </StackPanel>
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                    <ComboBox x:Name="PrintStatusFilter" Width="126" Height="36" Margin="0,0,8,0" SelectedIndex="0" SelectionChanged="OnPrintFilterChanged">
                      <ComboBoxItem Content="全部状态" Tag="all" />
                      <ComboBoxItem Content="排队中" Tag="queued" />
                      <ComboBoxItem Content="已完成" Tag="done" />
                      <ComboBoxItem Content="失败" Tag="failed" />
                    </ComboBox>
                    <Button Margin="0,0,8,0" Click="OnPullPrintJobsClick" Content="主动领取" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="0,0,8,0" Click="OnRefreshPrintJobsClick" Content="刷新" />
                    <Button Margin="8,0,0,0" Click="OnRetryPrintJobClick" Content="重试失败" />
                  </StackPanel>
                </DockPanel>
                <DataGrid x:Name="PrintJobsGrid" Grid.Row="1" Margin="0,20,0,0" MinHeight="560" ItemsSource="{Binding}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="任务 ID" Binding="{Binding Id}" Width="150" />
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="105" />
                    <DataGridTextColumn Header="打印机" Binding="{Binding Printer}" Width="180" />
                    <DataGridTextColumn Header="规格" Binding="{Binding Template}" Width="155" />
                    <DataGridTemplateColumn Header="状态" Width="100">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Border Padding="9,4" CornerRadius="12" Background="#E2E8F0" HorizontalAlignment="Left">
                            <Border.Style>
                              <Style TargetType="Border">
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding Status}" Value="queued"><Setter Property="Background" Value="#FEF3C7" /></DataTrigger>
                                  <DataTrigger Binding="{Binding Status}" Value="printing"><Setter Property="Background" Value="#DBEAFE" /></DataTrigger>
                                  <DataTrigger Binding="{Binding Status}" Value="completed"><Setter Property="Background" Value="#DCFCE7" /></DataTrigger>
                                  <DataTrigger Binding="{Binding Status}" Value="failed"><Setter Property="Background" Value="#FEE2E2" /></DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Status}" />
                          </Border>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="提交时间" Binding="{Binding SubmittedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                    <DataGridTextColumn Header="完成时间" Binding="{Binding FinishedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                    <DataGridTextColumn Header="错误信息" Binding="{Binding Error}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </Border>

            <Border x:Name="PrintConfigCard" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Visibility="Collapsed">
              <StackPanel>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="打印服务配置" />
                    <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="设置默认打印机、纸张尺寸和任务未指定参数时使用的打印规则。" />
                  </StackPanel>
                  <Button DockPanel.Dock="Right" Click="OnTogglePrintConfigClick" Content="收起配置" />
                </DockPanel>

                <StackPanel x:Name="PrintTemplateListPanel">
                  <DockPanel Margin="0,0,0,12">
                    <StackPanel DockPanel.Dock="Left">
                      <TextBlock FontSize="16" FontWeight="SemiBold" Text="打印模板列表" />
                      <TextBlock Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" Text="选择操作列中的“编辑”进入模板配置页面，模板 ID 保存后保持稳定。" />
                    </StackPanel>
                    <Button DockPanel.Dock="Right" Click="OnNewPrintTemplateClick" Content="添加新模板" Style="{StaticResource PrimaryButtonStyle}" />
                  </DockPanel>

                  <DataGrid x:Name="PrintTemplatesList" MinHeight="300" MaxHeight="460" SelectionChanged="OnPrintTemplateSelected">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="编号" Binding="{Binding TemplateNumber}" Width="70" />
                    <DataGridTextColumn Header="模板名称" Binding="{Binding Name}" Width="180" />
                    <DataGridTextColumn Header="模板 ID" Binding="{Binding Id}" Width="220" />
                    <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="90" />
                    <DataGridTextColumn Header="打印机" Binding="{Binding Printer}" Width="190" />
                    <DataGridTemplateColumn Header="打印机状态" Width="140">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Border Padding="8,4" HorizontalAlignment="Left" CornerRadius="4">
                            <Border.Style>
                              <Style TargetType="Border">
                                <Setter Property="Background" Value="#DCFCE7" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsPrinterAvailable}" Value="False">
                                    <Setter Property="Background" Value="#FEE2E2" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding PrinterStatusText}" FontWeight="SemiBold">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Foreground" Value="#166534" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPrinterAvailable}" Value="False">
                                      <Setter Property="Foreground" Value="#991B1B" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </Border>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="宽度(mm)" Binding="{Binding WidthMillimeters, StringFormat={}{0:0.##}}" Width="90" />
                    <DataGridTextColumn Header="高度(mm)" Binding="{Binding HeightMillimeters, StringFormat={}{0:0.##}}" Width="90" />
                    <DataGridTextColumn Header="方向" Binding="{Binding Orientation}" Width="90" />
                    <DataGridTextColumn Header="缩放" Binding="{Binding Mode}" Width="100" />
                    <DataGridTextColumn Header="份数" Binding="{Binding Copies}" Width="70" />
                    <DataGridTextColumn Header="偏移(mm)" Binding="{Binding OffsetXMillimeters, StringFormat={}{0:0.##}}" Width="90" />
                    <DataGridTemplateColumn Header="排序" Width="84">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal">
                            <Button Width="32" Height="30" Padding="0" Click="OnMovePrintTemplateUpClick" Content="↑" FontSize="16" IsEnabled="{Binding CanMoveUp}" ToolTip="上移模板" />
                            <Button Width="32" Height="30" Margin="6,0,0,0" Padding="0" Click="OnMovePrintTemplateDownClick" Content="↓" FontSize="16" IsEnabled="{Binding CanMoveDown}" ToolTip="下移模板" />
                          </StackPanel>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="操作" Width="260">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal">
                            <Button MinWidth="54" Height="30" Padding="8,0" Click="OnEditPrintTemplateClick" Content="编辑" />
                            <Button MinWidth="54" Height="30" Margin="6,0,0,0" Padding="8,0" Click="OnCopyPrintTemplateClick" Content="复制" />
                            <Button MinWidth="54" Height="30" Margin="6,0,0,0" Padding="8,0" Click="OnSetDefaultPrintTemplateClick" Content="默认" />
                            <Button MinWidth="54" Height="30" Margin="6,0,0,0" Padding="8,0" Click="OnDeletePrintTemplateClick" Content="删除" />
                          </StackPanel>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                  </DataGrid>
                </StackPanel>

                <Border x:Name="PrintTemplateEditorCard" Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                  <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                      <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="PrintTemplateEditorTitleText" FontSize="16" FontWeight="SemiBold" Text="添加打印模板" />
                        <TextBlock x:Name="PrintTemplateEditorSubtitleText" Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" Text="填写模板名称、打印机、尺寸、方向和二维码参数。" />
                      </StackPanel>
                      <Button DockPanel.Dock="Right" Click="OnCancelPrintTemplateEditClick" Content="返回模板列表" />
                    </DockPanel>

                    <Grid Margin="0,0,0,14">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="模板编号" />
                        <TextBox x:Name="PrintTemplateNumberTextBox" Margin="0,6,0,0" IsReadOnly="True" Background="#EEF2F7" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="模板名称" />
                        <TextBox x:Name="PrintTemplateNameTextBox" Margin="0,6,0,0" ToolTip="输入模板名称" />
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="模板 ID" />
                        <TextBox x:Name="PrintTemplateIdTextBox" Margin="0,6,0,0" IsReadOnly="True" Background="#EEF2F7" />
                      </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,14">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="模板用途" />
                      <ComboBox x:Name="PrintTemplateTypeComboBox" Margin="0,6,0,0" Height="36" SelectedValuePath="Tag">
                        <ComboBoxItem Content="通用标签" Tag="label" />
                        <ComboBoxItem Content="面单" Tag="shipping" />
                        <ComboBoxItem Content="厂家箱唛" Tag="manufacturer_box_mark" />
                        <ComboBoxItem Content="自定义" Tag="custom" />
                      </ComboBox>
                    </StackPanel>
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="默认打印机" />
                    <ComboBox x:Name="PrinterComboBox" Margin="0,6,0,0" Height="36" DisplayMemberPath="DisplayName" />
                  </StackPanel>
                  <Button Grid.Column="1" Margin="10,25,0,0" Click="OnRefreshPrintersClick" Content="刷新打印机" />
                </Grid>

                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="纸张尺寸预设" />
                    <ComboBox x:Name="PrintSizePresetComboBox" Margin="0,6,0,0" Height="36" DisplayMemberPath="Name" SelectionChanged="OnPrintSizePresetChanged" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="宽度 (mm)" />
                    <TextBox x:Name="PrintWidthTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="高度 (mm)" />
                    <TextBox x:Name="PrintHeightTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,16" Width="200" HorizontalAlignment="Left">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="份数（最多 5 份）" />
                  <TextBox x:Name="PrintCopiesTextBox" Margin="0,6,0,0" />
                </StackPanel>

                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="水平校准 (mm)" />
                    <TextBox x:Name="PrintOffsetXTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="纵向校准 (mm)" />
                    <TextBox x:Name="PrintOffsetYTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="安全边距 (mm)" />
                    <TextBox x:Name="PrintSafetyInsetTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="标签排版" />
                  <ComboBox x:Name="PrintLayoutStyleComboBox" Margin="0,6,0,0" Height="36" SelectedValuePath="Tag">
                    <ComboBoxItem Content="上下排版（二维码在上、文字在下）" Tag="stacked" />
                    <ComboBoxItem Content="左右排版（二维码在左、文字在右）" Tag="qr_left_text_right" />
                    <ComboBoxItem Content="库位码（左右各上下两个二维码，中间编码）" Tag="location_code_quad_qr" />
                    <ComboBoxItem Content="箱唛横向四码（左右二维码，中间信息）" Tag="box_mark_quad_qr" />
                  </ComboBox>
                </StackPanel>

                <DockPanel>
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Click="OnDetectPrintPaperClick" Content="检测纸张" />
                    <Button Margin="8,0,0,0" Click="OnOpenPrinterPreferencesClick" Content="打印首选项" />
                    <Button Margin="8,0,0,0" Click="OnPrintPreviewClick" Content="打印预览" />
                    <Button Margin="8,0,0,0" Click="OnSavePrintSettingsClick" Content="保存打印配置" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="8,0,0,0" Click="OnSavePrintTemplateClick" Content="保存模板" Style="{StaticResource PrimaryButtonStyle}" />
                  </StackPanel>
                </DockPanel>
                  </StackPanel>
                </Border>
                <TextBlock x:Name="PrintConfigStatusText" Margin="0,12,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="ProductsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="产品管理" />
                    <TextBlock Margin="0,6,0,14" Foreground="{StaticResource MutedTextBrush}" Text="优先查询本地产品和 SKU，本地无结果时自动从中心同步；选择 SKU 后可直接打印。" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                      <Button Click="OnRefreshCatalogClick" Content="刷新目录" />
                      <TextBlock x:Name="CatalogStatusText" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="本地目录等待同步" />
                    </StackPanel>
                  </StackPanel>
                  <StackPanel x:Name="ProductPrintActionsPanel" DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="ProductPrintTemplateText" MaxWidth="145" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                    <ComboBox x:Name="ProductPrintTemplateComboBox" Width="220" Height="36" Margin="8,0,0,0" Visibility="Collapsed" DisplayMemberPath="DisplayName" SelectionChanged="OnProductPrintTemplateSelectionChanged" />
                    <Button x:Name="ChangeProductPrintTemplateButton" Margin="8,0,0,0" Click="OnChangeProductPrintTemplateClick" Content="更换模板" />
                    <Button x:Name="ProductPrintButton" Margin="8,0,0,0" Click="OnPrintSelectedSkusClick" Content="打印标签" Style="{StaticResource PrimaryButtonStyle}" />
                  </StackPanel>
                </DockPanel>
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Grid Grid.ColumnSpan="4" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                      <Button x:Name="SkuModeButton" Click="OnSkuModeClick" Content="SKU" Style="{StaticResource PrimaryButtonStyle}" />
                      <Button x:Name="ProductModeButton" Margin="6,0,0,0" Click="OnProductModeClick" Content="产品" />
                    </StackPanel>
                    <TextBox x:Name="ProductQueryTextBox" Grid.Column="1" Height="36" Margin="18,0,12,0" VerticalContentAlignment="Center" ToolTip="输入编码、名称或规格" />
                    <Button x:Name="ProductQueryButton" Grid.Column="2" Click="OnQueryCurrentProductModeClick" Content="查询" Style="{StaticResource PrimaryButtonStyle}" />
                  </Grid>
                  <TextBox x:Name="ProductKeywordTextBox" Visibility="Collapsed" Grid.Column="0" ToolTip="产品编码或名称" />
                  <Button Visibility="Collapsed" Grid.Column="1" Margin="8,0,18,0" Click="OnSearchProductsClick" Content="查询产品" />
                  <TextBox x:Name="SkuKeywordTextBox" Visibility="Collapsed" Grid.Column="2" ToolTip="SKU编码或名称" />
                  <Button Visibility="Collapsed" Grid.Column="3" Margin="8,0,0,0" Click="OnSearchSkusClick" Content="查询 SKU" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <DataGrid x:Name="ProductsGrid" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Collapsed" Height="560" Margin="0" SelectionChanged="OnProductSelected" AutoGenerateColumns="False" GridLinesVisibility="None">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="产品编码" Binding="{Binding Code}" Width="140" />
                      <DataGridTextColumn Header="产品名称" Binding="{Binding Name}" Width="*" />
                      <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="110" />
                    </DataGrid.Columns>
                  </DataGrid>
                  <DataGrid x:Name="SkusGrid" Grid.Column="0" Grid.ColumnSpan="2" Height="560" Margin="0" AutoGenerateColumns="False" GridLinesVisibility="None" PreviewMouseLeftButtonDown="OnSkuGridPreviewMouseLeftButtonDown" SelectionMode="Extended" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                      <DataGridCheckBoxColumn Header="选择" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                      <DataGridTemplateColumn Header="SKU 编码" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <Border
                              Tag="CopyCodeTarget"
                              Background="Transparent"
                              Cursor="Hand"
                              ToolTip="单击或双击编码可复制"
                              PreviewMouseLeftButtonDown="OnCopySkuCodePreviewMouseLeftButtonDown">
                              <DockPanel>
                                <Button
                                  DockPanel.Dock="Right"
                                  Margin="6,0,0,0"
                                  Style="{StaticResource CopyCodeButtonStyle}"
                                  ToolTip="复制 SKU 编码"
                                  Focusable="False">
                                  <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE8C8;" />
                                </Button>
                                <TextBlock VerticalAlignment="Center" Text="{Binding Code}" TextTrimming="CharacterEllipsis" />
                              </DockPanel>
                            </Border>
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTextColumn Header="SKU 名称" Binding="{Binding Name}" Width="*" />
                      <DataGridTextColumn Header="规格" Binding="{Binding Spec}" Width="150" />
                      <DataGridTextColumn Header="产品" Binding="{Binding ProductCode}" Width="150" />
                    </DataGrid.Columns>
                  </DataGrid>
                </Grid>
                <DockPanel Margin="0,14,0,0">
                  <TextBlock x:Name="ProductStatusText" MaxWidth="430" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="正在加载本地 SKU" TextWrapping="Wrap" />
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="ProductPreviousPageButton" MinWidth="64" Click="OnPreviousProductPageClick" Content="上一页" IsEnabled="False" />
                    <TextBlock x:Name="ProductPageText" MinWidth="150" Margin="10,0" VerticalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="第 1 页" />
                    <Button x:Name="ProductNextPageButton" MinWidth="64" Click="OnNextProductPageClick" Content="下一页" IsEnabled="False" />
                    <Border Width="1" Height="24" Margin="14,0" Background="#E2E8F0" />
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="二维码前缀" />
                    <TextBox x:Name="SkuQrPrefixTextBox" Width="76" Margin="8,0,0,0" Text="T" />
                    <Button Margin="8,0,0,0" Click="OnSaveQrPrefixClick" Content="保存" />
                  </StackPanel>
                </DockPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="BoxLabelsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <DockPanel Margin="0,0,0,14">
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="箱唛查询" />
                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="本地查询箱唛、产品和 SKU；集运订单候选项从中心在线获取。" />
                  </StackPanel>
                  <Button DockPanel.Dock="Right" Click="OnRefreshCatalogClick" Content="同步本地数据" />
                </DockPanel>

                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="箱唛 / 箱号 / 厂家订单" />
                    <TextBox x:Name="BoxLabelKeywordTextBox" Height="36" Margin="0,6,0,0" VerticalContentAlignment="Center" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="产品" />
                    <Grid Margin="0,6,0,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ComboBox x:Name="BoxLabelProductComboBox" Height="36" IsEditable="True" DisplayMemberPath="Code" SelectionChanged="OnBoxLabelProductChanged" />
                      <Button Grid.Column="1" Margin="6,0,0,0" Click="OnSearchBoxLabelProductsClick" Content="查找" />
                    </Grid>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="SKU" />
                    <Grid Margin="0,6,0,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ComboBox x:Name="BoxLabelSkuComboBox" Height="36" IsEditable="True" DisplayMemberPath="Code" />
                      <Button Grid.Column="1" Margin="6,0,0,0" Click="OnSearchBoxLabelSkusClick" Content="查找" />
                    </Grid>
                  </StackPanel>
                  <StackPanel Grid.Column="3">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="集运订单号" />
                    <Grid Margin="0,6,0,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <ComboBox x:Name="BoxLabelConsolidationComboBox" Height="36" IsEditable="True" DisplayMemberPath="DisplayName" />
                      <Button Grid.Column="1" Margin="6,0,0,0" Click="OnSearchConsolidationOrdersClick" Content="在线" />
                    </Grid>
                  </StackPanel>
                </Grid>

                <DockPanel>
                  <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <ComboBox x:Name="BoxLabelStatusComboBox" Width="140" Height="36" SelectedValuePath="Tag" SelectedIndex="0">
                      <ComboBoxItem Content="全部箱唛状态" Tag="" />
                      <ComboBoxItem Content="正常" Tag="normal" />
                      <ComboBoxItem Content="已作废" Tag="voided" />
                      <ComboBoxItem Content="短装" Tag="shorted" />
                      <ComboBoxItem Content="已收货" Tag="received" />
                      <ComboBoxItem Content="破损" Tag="damaged" />
                      <ComboBoxItem Content="异常" Tag="exception" />
                    </ComboBox>
                    <ComboBox x:Name="BoxLabelReceivingComboBox" Width="140" Height="36" Margin="8,0,0,0" SelectedValuePath="Tag" SelectedIndex="0">
                      <ComboBoxItem Content="全部收货状态" Tag="" />
                      <ComboBoxItem Content="待收货" Tag="pending" />
                      <ComboBoxItem Content="扫码中" Tag="scanning" />
                      <ComboBoxItem Content="已收货" Tag="received" />
                      <ComboBoxItem Content="破损" Tag="damaged" />
                    </ComboBox>
                    <Button Margin="8,0,0,0" Click="OnQueryBoxLabelsClick" Content="查询" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="8,0,0,0" Click="OnResetBoxLabelsClick" Content="重置" />
                  </StackPanel>
                  <TextBlock x:Name="BoxLabelCatalogStatusText" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="等待本地箱唛同步" />
                </DockPanel>
              </StackPanel>
            </Border>

            <Grid Margin="0,18,0,0">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="380" /></Grid.ColumnDefinitions>
              <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,18,0">
                <Grid>
                  <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                  <DockPanel Margin="0,0,0,14">
                    <StackPanel DockPanel.Dock="Left">
                      <TextBlock FontSize="17" FontWeight="SemiBold" Text="箱唛列表" />
                      <TextBlock x:Name="BoxLabelResultText" Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" Text="尚未查询" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                      <StackPanel Width="190">
                        <ComboBox x:Name="BoxLabelPrintTemplateComboBox" Width="220" Height="36" DisplayMemberPath="DisplayName" SelectionChanged="OnBoxLabelPrintTemplateSelected" />
                        <TextBlock x:Name="BoxLabelTemplateStatusText" Margin="2,3,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Text="正在读取模板" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                      </StackPanel>
                      <Button x:Name="BoxLabelEditTemplateButton" Margin="6,0,0,0" Click="OnEditSelectedBoxMarkTemplateClick" Style="{StaticResource CopyCodeButtonStyle}" ToolTip="编辑当前厂家箱唛模板">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE70F;" />
                      </Button>
                      <TextBox x:Name="BoxLabelCopiesTextBox" Width="48" Height="36" Margin="8,0,0,0" Text="1" TextAlignment="Center" VerticalContentAlignment="Center" ToolTip="打印份数，最多 5 份" />
                      <Button x:Name="BoxLabelPreviewButton" Margin="8,0,0,0" Click="OnPreviewSelectedBoxLabelsClick" Style="{StaticResource CopyCodeButtonStyle}" ToolTip="预览勾选或当前箱唛">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE890;" />
                      </Button>
                      <Button x:Name="BoxLabelPrintButton" Margin="8,0,0,0" Click="OnPrintSelectedBoxLabelsClick" Content="打印箱唛" Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                  </DockPanel>
                  <DataGrid x:Name="BoxLabelsGrid" Grid.Row="1" Height="520" AutoGenerateColumns="False" GridLinesVisibility="None" PreviewMouseLeftButtonDown="OnBoxLabelGridPreviewMouseLeftButtonDown" SelectionChanged="OnBoxLabelSelected" SelectionMode="Extended" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                      <DataGridCheckBoxColumn Header="选择" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                      <DataGridTemplateColumn Header="箱唛码" Width="145">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <Border
                              Tag="CopyCodeTarget"
                              Background="Transparent"
                              Cursor="Hand"
                              ToolTip="单击或双击编码可复制"
                              PreviewMouseLeftButtonDown="OnCopyBoxLabelCodePreviewMouseLeftButtonDown">
                              <DockPanel>
                                <Button
                                  DockPanel.Dock="Right"
                                  Margin="6,0,0,0"
                                  Style="{StaticResource CopyCodeButtonStyle}"
                                  ToolTip="复制箱唛码"
                                  Focusable="False">
                                  <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE8C8;" />
                                </Button>
                                <TextBlock VerticalAlignment="Center" Text="{Binding LabelCode}" TextTrimming="CharacterEllipsis" />
                              </DockPanel>
                            </Border>
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTextColumn Header="SKU / 混箱" Binding="{Binding SkuDisplay}" Width="220" />
                      <DataGridTextColumn Header="厂家订单" Binding="{Binding SupplierOrder.Code}" Width="140" />
                      <DataGridTextColumn Header="集运订单" Binding="{Binding ConsolidationDisplay}" Width="140" />
                      <DataGridTextColumn Header="箱唛状态" Binding="{Binding StatusLabel}" Width="90" />
                      <DataGridTextColumn Header="仓库收货" Binding="{Binding ReceivingDisplay}" Width="90" />
                      <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="145" />
                    </DataGrid.Columns>
                  </DataGrid>
                  <DockPanel Grid.Row="2" Margin="0,14,0,0">
                    <TextBlock x:Name="BoxLabelPageText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="第 1 页" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                      <Button x:Name="PreviousBoxLabelPageButton" Click="OnPreviousBoxLabelPageClick" Content="上一页" />
                      <Button x:Name="NextBoxLabelPageButton" Margin="8,0,0,0" Click="OnNextBoxLabelPageClick" Content="下一页" />
                    </StackPanel>
                  </DockPanel>
                </Grid>
              </Border>

              <Border x:Name="BoxLabelDetailPanel" Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock FontSize="17" FontWeight="SemiBold" Text="箱唛详情" />
                  <TextBlock Margin="0,12,0,0" Foreground="{StaticResource MutedTextBrush}" Text="箱唛编码" />
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding LabelCode, TargetNullValue=-}" TextWrapping="Wrap" />
                  <UniformGrid Columns="2" Margin="0,14,0,0">
                    <StackPanel Margin="0,0,10,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="箱号" /><TextBlock Text="{Binding BoxNo, TargetNullValue=-}" TextWrapping="Wrap" /></StackPanel>
                    <StackPanel Margin="0,0,0,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="箱规" /><TextBlock Text="{Binding CaseSpecName, TargetNullValue=-}" TextWrapping="Wrap" /></StackPanel>
                    <StackPanel Margin="0,0,10,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="厂家" /><TextBlock Text="{Binding ManufacturerName, TargetNullValue=-}" TextWrapping="Wrap" /></StackPanel>
                    <StackPanel Margin="0,0,0,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="厂家订单" /><TextBlock Text="{Binding SupplierOrder.Code, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,10,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="采购订单" /><TextBlock Text="{Binding PurchaseOrder.Code, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,0,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="集运订单" /><TextBlock Text="{Binding ConsolidationOrder.Code, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,10,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="集运柜" /><TextBlock Text="{Binding ConsolidationContainer, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,0,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="集运收货单" /><TextBlock Text="{Binding CentralReceipt.Code, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,10,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="收货会话" /><TextBlock Text="{Binding Receiving.Session.Code, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,0,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="海外仓收货单" /><TextBlock Text="{Binding Receiving.ReceivingRecord.Code, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,10,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="仓库" /><TextBlock Text="{Binding Receiving.WarehouseCode, TargetNullValue=-}" /></StackPanel>
                    <StackPanel Margin="0,0,0,12"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="库位" /><TextBlock Text="{Binding Receiving.LocationCode, TargetNullValue=-}" /></StackPanel>
                  </UniformGrid>
                  <TextBlock Margin="0,4,0,6" FontWeight="SemiBold" Text="产品与 SKU" />
                  <DataGrid Height="180" ItemsSource="{Binding SkuItems}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="产品" Binding="{Binding ProductCode}" Width="95" />
                      <DataGridTextColumn Header="SKU" Binding="{Binding SkuCode}" Width="*" />
                      <DataGridTextColumn Header="数量" Binding="{Binding QuantityPerBox}" Width="55" />
                    </DataGrid.Columns>
                  </DataGrid>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="AdvancedPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="AdvancedContentStack" Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="应用控制" />
                  <TextBlock x:Name="ApplicationControlStatusText" Margin="0,6,16,0" Foreground="{StaticResource MutedTextBrush}" Text="管理开机启动和应用进程。" TextWrapping="Wrap" />
                  <CheckBox x:Name="LaunchAtSignInCheckBox" Margin="0,12,0,0" Checked="OnLaunchAtSignInChanged" Unchecked="OnLaunchAtSignInChanged" Content="登录 Windows 时启动 FSCM Edge" />
                </StackPanel>
                <Button DockPanel.Dock="Right" VerticalAlignment="Center" Click="OnRestartApplicationClick" Content="重启应用" />
              </DockPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="应用更新" />
                  <TextBlock x:Name="UpdateStatusText" Margin="0,6,16,0" Foreground="{StaticResource MutedTextBrush}" Text="启动后会自动检查 FSCM Edge 更新。" TextWrapping="Wrap" />
                </StackPanel>
                <Button x:Name="CheckForUpdatesButton" DockPanel.Dock="Right" VerticalAlignment="Center" Click="OnCheckForUpdatesClick" Content="检查更新" />
              </DockPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="后端服务控制" />
                <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="这些操作会影响本地边缘服务，仅在排查或配置变更后使用。" />
                <StackPanel Orientation="Horizontal">
                  <Button Click="OnStartClick" Content="启动" Style="{StaticResource PrimaryButtonStyle}" />
                  <Button Margin="8,0,0,0" Click="OnStopClick" Content="停止" Style="{StaticResource DangerButtonStyle}" />
                  <Button Margin="8,0,0,0" Click="OnRestartClick" Content="重启" />
                  <Button Margin="8,0,0,0" Click="OnOpenRuntimeClick" Content="打开目录" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="180" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="中心打印任务领取" />
                  <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="边缘服务定期向中心领取待执行任务。保存后需要重启边缘服务生效。" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="领取周期（秒）" />
                  <TextBox x:Name="PrintPollIntervalTextBox" Margin="0,6,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Margin="12,27,0,0" Click="OnSavePrintPollIntervalClick" Content="保存" Style="{StaticResource PrimaryButtonStyle}" />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <UniformGrid Columns="2">
                <StackPanel Margin="0,0,18,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="端口" />
                  <TextBlock x:Name="AdvancedPortText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="进程 ID" />
                  <TextBlock x:Name="AdvancedProcessText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,18,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="二进制文件" />
                  <TextBlock x:Name="AdvancedBinaryText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="配置文件" />
                  <TextBlock x:Name="AdvancedConfigText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,18,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="运行目录" />
                  <TextBlock x:Name="AdvancedRuntimePathText" Margin="0,5,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="日志目录" />
                  <TextBlock x:Name="AdvancedLogPathText" Margin="0,5,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
              </UniformGrid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="运行版本" />
                  <TextBlock x:Name="AdvancedVersionText" Margin="0,12,0,0" />
                  <TextBlock x:Name="AdvancedCommitText" Margin="0,8,0,0" TextWrapping="Wrap" />
                  <TextBlock x:Name="AdvancedApiText" Margin="0,8,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="日志文件" />
                  <Button Margin="0,12,0,0" HorizontalAlignment="Left" Click="OnOpenStdoutLogClick" Content="打开 stdout" />
                  <Button Margin="0,8,0,0" HorizontalAlignment="Left" Click="OnOpenStderrLogClick" Content="打开 stderr" />
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>
