<Window
  x:Class="Fscm.Edge.Win.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="FSCM Edge"
  Width="1180"
  Height="760"
  MinWidth="980"
  MinHeight="640"
  Icon="Assets/fscm-edge.ico"
  WindowState="Maximized"
  WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F7FB" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0" />
    <SolidColorBrush x:Key="TextBrush" Color="#111827" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />

    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="StatusPillStyle" TargetType="Border">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
      <Setter Property="Margin" Value="10,3" />
      <Setter Property="Padding" Value="14,11" />
      <Setter Property="Foreground" Value="#334155" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border
              x:Name="ItemBorder"
              Background="Transparent"
              CornerRadius="8"
              Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF1FF" />
                <Setter Property="Foreground" Value="#1D4ED8" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Button">
      <Setter Property="MinWidth" Value="88" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#1E293B" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#2563EB" />
      <Setter Property="BorderBrush" Value="#2563EB" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#DC2626" />
      <Setter Property="BorderBrush" Value="#DC2626" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="CanUserDeleteRows" Value="False" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="RowHeight" Value="52" />
      <Setter Property="AlternationCount" Value="2" />
      <Setter Property="BorderBrush" Value="#E2E8F0" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Height" Value="44" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#334155" />
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#E2E8F0" />
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="DataGridRow">
      <Setter Property="Height" Value="52" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Style.Triggers>
        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
          <Setter Property="Background" Value="#F8FAFC" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#EFF6FF" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#DBEAFE" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Background="{StaticResource PageBackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border
      Grid.Column="0"
      Background="#FFFFFF"
      BorderBrush="#E2E8F0"
      BorderThickness="0,0,1,0">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Margin="22,24,22,18">
          <TextBlock
            FontSize="24"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
            Text="FSCM Edge" />
          <TextBlock
            Margin="0,6,0,0"
            Foreground="{StaticResource MutedTextBrush}"
            Text="本地边缘节点" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Margin="18" Padding="14" Background="#F8FAFC" CornerRadius="8">
          <StackPanel>
            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="本地地址" />
            <TextBlock
              x:Name="SidebarLanText"
              Margin="0,5,0,0"
              FontWeight="SemiBold"
              TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <ListBox
          x:Name="NavigationList"
          BorderThickness="0"
          ItemContainerStyle="{StaticResource NavItemStyle}"
          SelectionChanged="OnNavigationChanged"
          SelectedIndex="0">
          <ListBoxItem Tag="Home">总览</ListBoxItem>
          <ListBoxItem Tag="Products">产品管理</ListBoxItem>
          <ListBoxItem Tag="Terminals">在线终端</ListBoxItem>
          <ListBoxItem Tag="LabelPrint">标签打印</ListBoxItem>
          <ListBoxItem Tag="Print">打印任务</ListBoxItem>
          <ListBoxItem Tag="PrintConfig">打印配置</ListBoxItem>
          <ListBoxItem Tag="Advanced">高级设置</ListBoxItem>
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border
        Grid.Row="0"
        Background="#FFFFFF"
        BorderBrush="#E2E8F0"
        BorderThickness="0,0,0,1"
        Padding="28,20">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Left">
            <TextBlock
              x:Name="PageTitleText"
              FontSize="24"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
              Text="总览" />
            <TextBlock
              x:Name="PageSubtitleText"
              Margin="0,5,0,0"
              Foreground="{StaticResource MutedTextBrush}"
              Text="查看边缘节点最关键的运行状态。" />
          </StackPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
            <Border x:Name="HeaderStatusPill" Style="{StaticResource StatusPillStyle}" Background="#FEF3C7" Margin="0,0,12,0">
              <TextBlock x:Name="HeaderStatusText" FontWeight="SemiBold" Foreground="#92400E" Text="Checking" />
            </Border>
            <Button Click="OnRefreshClick" Content="刷新" Style="{StaticResource PrimaryButtonStyle}" />
          </StackPanel>
        </DockPanel>
      </Border>

      <Grid Grid.Row="1">
        <ScrollViewer x:Name="HomePage" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <UniformGrid Columns="3">
              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="本地服务" />
                  <Border x:Name="LocalStatusBadge" Style="{StaticResource StatusPillStyle}" Margin="0,12,0,10" Background="#FEF3C7">
                    <TextBlock x:Name="LocalStatusText" FontWeight="SemiBold" Foreground="#92400E" Text="Checking" />
                  </Border>
                  <TextBlock x:Name="LocalStatusMessageText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,14">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="远端服务" />
                  <Border x:Name="RemoteStatusBadge" Style="{StaticResource StatusPillStyle}" Margin="0,12,0,10" Background="#E2E8F0">
                    <TextBlock x:Name="RemoteStatusText" FontWeight="SemiBold" Foreground="#475569" Text="未配置" />
                  </Border>
                  <TextBlock x:Name="RemoteStatusMessageText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="节点注册" />
                  <Border x:Name="RegistrationStatusBadge" Style="{StaticResource StatusPillStyle}" Margin="0,12,0,10" Background="#E2E8F0">
                    <TextBlock x:Name="RegistrationStatusText" FontWeight="SemiBold" Foreground="#475569" Text="未注册" />
                  </Border>
                  <TextBlock x:Name="RegistrationMessageText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <UniformGrid Columns="4" Margin="0,0,0,14">
              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="连接终端" />
                  <TextBlock x:Name="HomeTerminalCountText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#0F766E" Text="0" />
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="已探测的局域网终端" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="打印排队" />
                  <TextBlock x:Name="HomePrintQueueText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#C2410C" Text="0" />
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="等待本机处理的任务" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="已处理打印" />
                  <TextBlock x:Name="HomePrintProcessedText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#2563EB" Text="0" />
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="当前本地任务记录" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="缓存效率" />
                  <TextBlock x:Name="HomeCacheHitRateText" Margin="0,10,0,3" FontSize="28" FontWeight="SemiBold" Foreground="#7C3AED" Text="--" />
                  <TextBlock x:Name="HomeCacheSizeText" Foreground="{StaticResource MutedTextBrush}" Text="等待缓存状态" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="局域网访问地址" />
                  <TextBlock x:Name="HomeLanText" Margin="0,6,18,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock x:Name="HomeWebLabelUrlText" Margin="0,8,18,0" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                  <Button Margin="0,10,18,0" HorizontalAlignment="Left" Click="OnCopyLabelPrintUrlClick" Content="复制 Web 打印地址" />
                  <Image x:Name="HomeWebLabelQrImage" Width="116" Height="116" Margin="0,14,18,0" Stretch="Uniform" ToolTip="扫描打开 Web 标签打印页面" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="边缘代理版本" />
                  <TextBlock x:Name="HomeVersionText" Margin="0,6,18,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="缓存策略" />
                  <TextBlock x:Name="HomeSyncedText" Margin="0,6,0,0" FontWeight="SemiBold" Text="标准" />
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="RemotePage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="远端服务器" />
                <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="配置 FSCM 中心服务地址，用于透明代理业务请求、节点注册和发现。" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="服务器地址" />
                <TextBox x:Name="CenterUrlTextBox" Margin="0,6,0,14" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="工作空间 ID" />
                <TextBox x:Name="NamespaceIdTextBox" Margin="0,6,0,14" />
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Node ID (stable identity)" />
                    <TextBox x:Name="NodeIdTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Node name (display)" />
                    <TextBox x:Name="NodeNameTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="LAN base URL override (optional)" />
                <TextBox x:Name="LanBaseUrlTextBox" Margin="0,6,0,14" ToolTip="Leave empty to select an active private LAN IPv4 automatically. Example: http://192.168.1.20:8089" />
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="API Token" />
                <PasswordBox x:Name="ApiTokenPasswordBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <TextBlock
                    x:Name="ApiTokenStatusText"
                    Grid.Column="1"
                    Margin="14,25,0,0"
                    Foreground="{StaticResource MutedTextBrush}"
                    VerticalAlignment="Top" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="RemoteDetailText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                  <Button x:Name="TestRemoteButton" Grid.Column="1" Margin="12,0,0,0" Click="OnTestRemoteClick" Content="测试连接" />
                  <Button Grid.Column="2" Margin="8,0,0,0" Click="OnSaveRemoteClick" Content="保存配置" Style="{StaticResource PrimaryButtonStyle}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="节点信息" />
                  <TextBlock x:Name="RemoteNodeNameText" Margin="0,14,0,0" />
                  <TextBlock x:Name="RemoteLanText" Margin="0,8,0,0" TextWrapping="Wrap" />
                  <TextBlock x:Name="RemoteCheckedText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="服务能力" />
                  <ItemsControl x:Name="CapabilitiesItems" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,8,8" Padding="10,5" Background="#EFF6FF" CornerRadius="12">
                          <TextBlock Foreground="#1D4ED8" Text="{Binding}" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                </StackPanel>
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="边缘代理缓存" />
                <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="缓存仅保存在内存中，重启后自动清空。配置修改后需重启边缘服务。" />
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="缓存模式" />
                    <ComboBox x:Name="CacheModeComboBox" Margin="0,6,0,0" Height="36" SelectedValuePath="Tag">
                      <ComboBoxItem Content="关闭" Tag="disabled" />
                      <ComboBoxItem Content="标准" Tag="standard" />
                      <ComboBoxItem Content="积极" Tag="aggressive" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="内存上限 (MB)" />
                    <TextBox x:Name="CacheMemoryTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="单项上限 (MB)" />
                    <TextBox x:Name="CacheObjectTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="3">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="过期兜底 (小时)" />
                    <TextBox x:Name="CacheStaleHoursTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>
                <DockPanel>
                  <TextBlock x:Name="CacheStatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="等待边缘服务状态" TextWrapping="Wrap" />
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Click="OnRefreshCacheClick" Content="刷新状态" />
                    <Button Margin="8,0,0,0" Click="OnClearCacheClick" Content="清空缓存" />
                  </StackPanel>
                </DockPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <Grid x:Name="TerminalsPage" Visibility="Collapsed" Margin="28">
          <Border Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="本地可用终端" />
                  <TextBlock Margin="0,6,0,14" Foreground="{StaticResource MutedTextBrush}" Text="访问过本地 /edge/probe 的局域网客户端会显示在这里。" />
                </StackPanel>
                <Button DockPanel.Dock="Right" Click="OnRefreshTerminalsClick" Content="刷新终端" />
              </DockPanel>
              <DataGrid x:Name="TerminalsGrid" Grid.Row="1" ItemsSource="{Binding}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="终端名称" Binding="{Binding Name}" Width="160" />
                  <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="140" />
                  <DataGridTextColumn Header="User-Agent" Binding="{Binding UserAgent}" Width="*" />
                  <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="90" />
                  <DataGridTextColumn Header="最后探测时间" Binding="{Binding LastSeenAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
                  <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
        </Grid>

        <ScrollViewer x:Name="LabelPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="标签打印" />
                <TextBlock Margin="0,6,0,18" Foreground="{StaticResource MutedTextBrush}" Text="选择标签模板后打印，二维码在上方，字符串在下方。" />
                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="打印模板" />
                    <ComboBox x:Name="LabelTemplateComboBox" Margin="0,6,0,0" Height="36" DisplayMemberPath="Name" SelectionChanged="OnLabelTemplateSelected" />
                  </StackPanel>
                  <UniformGrid Grid.Column="1" Columns="4">
                    <StackPanel Margin="0,0,10,0">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="打印机" />
                      <TextBlock x:Name="LabelPrinterText" Margin="0,5,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="纸张" />
                      <TextBlock x:Name="LabelPaperText" Margin="0,5,0,0" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Margin="0,0,10,0">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="方向" />
                      <TextBlock x:Name="LabelOrientationText" Margin="0,5,0,0" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="二维码前缀" />
                      <TextBox x:Name="LabelPrefixTextBox" Margin="0,5,0,0" Height="32" MaxLength="20" ToolTip="标签二维码前缀；留空表示不添加前缀" />
                    </StackPanel>
                  </UniformGrid>
                </Grid>
                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="标签内容" />
                    <TextBox x:Name="LabelTextBox" Margin="0,6,0,0" Height="36" AcceptsReturn="False" TextWrapping="NoWrap" ToolTip="输入二维码和标签下方显示的字符串" />
                  </StackPanel>
                  <Border Grid.Column="1" Width="180" Height="120" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="14">
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="当前模板" />
                      <TextBlock x:Name="LabelTemplateSummaryText" Margin="0,5,0,0" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock x:Name="LabelModeText" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                  </Border>
                </Grid>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="LabelStatusText" Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                  <Button DockPanel.Dock="Right" Click="OnPrintLabelClick" Content="打印标签" Style="{StaticResource PrimaryButtonStyle}" />
                </DockPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="PrintPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border x:Name="PrintJobsCard" Style="{StaticResource CardStyle}" MinHeight="420">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="打印任务" />
                    <TextBlock x:Name="PrintQueueSummaryText" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="正在加载打印任务..." />
                  </StackPanel>
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                    <ComboBox x:Name="PrintStatusFilter" Width="126" Height="36" Margin="0,0,8,0" SelectedIndex="0" SelectionChanged="OnPrintFilterChanged">
                      <ComboBoxItem Content="全部状态" Tag="all" />
                      <ComboBoxItem Content="排队中" Tag="queued" />
                      <ComboBoxItem Content="已完成" Tag="done" />
                      <ComboBoxItem Content="失败" Tag="failed" />
                    </ComboBox>
                    <Button Margin="0,0,8,0" Click="OnPullPrintJobsClick" Content="主动领取" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="0,0,8,0" Click="OnRefreshPrintJobsClick" Content="刷新" />
                    <Button Margin="8,0,0,0" Click="OnRetryPrintJobClick" Content="重试失败" />
                  </StackPanel>
                </DockPanel>
                <DataGrid x:Name="PrintJobsGrid" Grid.Row="1" Margin="0,20,0,0" MinHeight="560" ItemsSource="{Binding}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="任务 ID" Binding="{Binding Id}" Width="150" />
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="105" />
                    <DataGridTextColumn Header="打印机" Binding="{Binding Printer}" Width="180" />
                    <DataGridTextColumn Header="规格" Binding="{Binding Template}" Width="155" />
                    <DataGridTemplateColumn Header="状态" Width="100">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Border Padding="9,4" CornerRadius="12" Background="#E2E8F0" HorizontalAlignment="Left">
                            <Border.Style>
                              <Style TargetType="Border">
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding Status}" Value="queued"><Setter Property="Background" Value="#FEF3C7" /></DataTrigger>
                                  <DataTrigger Binding="{Binding Status}" Value="printing"><Setter Property="Background" Value="#DBEAFE" /></DataTrigger>
                                  <DataTrigger Binding="{Binding Status}" Value="completed"><Setter Property="Background" Value="#DCFCE7" /></DataTrigger>
                                  <DataTrigger Binding="{Binding Status}" Value="failed"><Setter Property="Background" Value="#FEE2E2" /></DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Status}" />
                          </Border>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="提交时间" Binding="{Binding SubmittedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                    <DataGridTextColumn Header="完成时间" Binding="{Binding FinishedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                    <DataGridTextColumn Header="错误信息" Binding="{Binding Error}" Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </Border>

            <Border x:Name="PrintConfigCard" Style="{StaticResource CardStyle}" Margin="0,18,0,0" Visibility="Collapsed">
              <StackPanel>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="打印服务配置" />
                    <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="设置默认打印机、纸张尺寸和任务未指定参数时使用的打印规则。" />
                  </StackPanel>
                  <Button DockPanel.Dock="Right" Click="OnTogglePrintConfigClick" Content="收起配置" />
                </DockPanel>

                <DockPanel Margin="0,0,0,12">
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="打印模板列表" />
                    <TextBlock Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" Text="手机终端可直接选择模板打印，模板 ID 保存后保持稳定。" />
                  </StackPanel>
                  <Button DockPanel.Dock="Right" Click="OnNewPrintTemplateClick" Content="添加新模板" Style="{StaticResource PrimaryButtonStyle}" />
                </DockPanel>

                <DataGrid x:Name="PrintTemplatesList" MinHeight="300" MaxHeight="460" SelectionChanged="OnPrintTemplateSelected">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="模板名称" Binding="{Binding Name}" Width="180" />
                    <DataGridTextColumn Header="模板 ID" Binding="{Binding Id}" Width="220" />
                    <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="90" />
                    <DataGridTextColumn Header="打印机" Binding="{Binding Printer}" Width="190" />
                    <DataGridTextColumn Header="宽度(mm)" Binding="{Binding WidthMillimeters, StringFormat={}{0:0.##}}" Width="90" />
                    <DataGridTextColumn Header="高度(mm)" Binding="{Binding HeightMillimeters, StringFormat={}{0:0.##}}" Width="90" />
                    <DataGridTextColumn Header="方向" Binding="{Binding Orientation}" Width="90" />
                    <DataGridTextColumn Header="缩放" Binding="{Binding Mode}" Width="100" />
                    <DataGridTextColumn Header="份数" Binding="{Binding Copies}" Width="70" />
                    <DataGridTextColumn Header="偏移(mm)" Binding="{Binding OffsetXMillimeters, StringFormat={}{0:0.##}}" Width="90" />
                    <DataGridTemplateColumn Header="操作" Width="260">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal">
                            <Button MinWidth="54" Height="30" Padding="8,0" Click="OnEditPrintTemplateClick" Content="编辑" />
                            <Button MinWidth="54" Height="30" Margin="6,0,0,0" Padding="8,0" Click="OnCopyPrintTemplateClick" Content="复制" />
                            <Button MinWidth="54" Height="30" Margin="6,0,0,0" Padding="8,0" Click="OnSetDefaultPrintTemplateClick" Content="默认" />
                            <Button MinWidth="54" Height="30" Margin="6,0,0,0" Padding="8,0" Click="OnDeletePrintTemplateClick" Content="删除" />
                          </StackPanel>
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="PrintTemplateEditorCard" Margin="0,16,0,0" Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                  <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                      <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="PrintTemplateEditorTitleText" FontSize="16" FontWeight="SemiBold" Text="添加打印模板" />
                        <TextBlock x:Name="PrintTemplateEditorSubtitleText" Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" Text="填写模板名称、打印机、尺寸、方向和二维码参数。" />
                      </StackPanel>
                      <Button DockPanel.Dock="Right" Click="OnCancelPrintTemplateEditClick" Content="关闭" />
                    </DockPanel>

                    <Grid Margin="0,0,0,14">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="模板名称" />
                        <TextBox x:Name="PrintTemplateNameTextBox" Margin="0,6,0,0" ToolTip="输入模板名称" />
                      </StackPanel>
                      <StackPanel Grid.Column="1">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="模板 ID" />
                        <TextBox x:Name="PrintTemplateIdTextBox" Margin="0,6,0,0" IsReadOnly="True" Background="#EEF2F7" />
                      </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,14">
                      <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="模板用途" />
                      <ComboBox x:Name="PrintTemplateTypeComboBox" Margin="0,6,0,0" Height="36" SelectedValuePath="Tag">
                        <ComboBoxItem Content="通用标签" Tag="label" />
                        <ComboBoxItem Content="面单" Tag="shipping" />
                        <ComboBoxItem Content="厂家箱唛" Tag="manufacturer_box_mark" />
                        <ComboBoxItem Content="自定义" Tag="custom" />
                      </ComboBox>
                    </StackPanel>
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="默认打印机" />
                    <ComboBox x:Name="PrinterComboBox" Margin="0,6,0,0" Height="36" DisplayMemberPath="DisplayName" />
                  </StackPanel>
                  <Button Grid.Column="1" Margin="10,25,0,0" Click="OnRefreshPrintersClick" Content="刷新打印机" />
                </Grid>

                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="纸张尺寸预设" />
                    <ComboBox x:Name="PrintSizePresetComboBox" Margin="0,6,0,0" Height="36" DisplayMemberPath="Name" SelectionChanged="OnPrintSizePresetChanged" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="宽度 (mm)" />
                    <TextBox x:Name="PrintWidthTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="高度 (mm)" />
                    <TextBox x:Name="PrintHeightTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="纸张方向" />
                    <ComboBox x:Name="PrintOrientationComboBox" Margin="0,6,0,0" Height="36" SelectedValuePath="Tag">
                      <ComboBoxItem Content="横向（40 x 60 mm）" Tag="landscape" />
                      <ComboBoxItem Content="纵向（60 x 40 mm）" Tag="portrait" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="默认打印模式" />
                    <ComboBox x:Name="PrintModeComboBox" Margin="0,6,0,0" Height="36" SelectedValuePath="Tag">
                      <ComboBoxItem Content="等比适配" Tag="fit" />
                      <ComboBoxItem Content="原始尺寸" Tag="actual_size" />
                      <ComboBoxItem Content="填充纸张" Tag="fill" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="份数" />
                    <TextBox x:Name="PrintCopiesTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="水平校准 (mm)" />
                    <TextBox x:Name="PrintOffsetXTextBox" Margin="0,6,0,0" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Margin="0,24,0,0" Foreground="{StaticResource MutedTextBrush}" Text="正数向右移动，负数向左移动；建议先从 1.0 mm 开始测试。" TextWrapping="Wrap" />
                </Grid>

                <DockPanel>
                  <TextBlock x:Name="PrintConfigStatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Click="OnPrintPreviewClick" Content="打印预览" />
                    <Button Margin="8,0,0,0" Click="OnSavePrintSettingsClick" Content="保存打印配置" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="8,0,0,0" Click="OnSavePrintTemplateClick" Content="保存模板" Style="{StaticResource PrimaryButtonStyle}" />
                  </StackPanel>
                </DockPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="ProductsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="产品管理" />
                    <TextBlock Margin="0,6,0,14" Foreground="{StaticResource MutedTextBrush}" Text="查询中心产品和 SKU，选择模板后直接创建二维码打印任务。" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                      <Button Click="OnRefreshCatalogClick" Content="刷新目录" />
                      <TextBlock x:Name="CatalogStatusText" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="本地目录等待同步" />
                    </StackPanel>
                  </StackPanel>
                  <StackPanel x:Name="ProductPrintActionsPanel" DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="ProductPrintTemplateText" MaxWidth="145" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                    <ComboBox x:Name="ProductPrintTemplateComboBox" Width="190" Height="36" Margin="8,0,0,0" Visibility="Collapsed" DisplayMemberPath="Name" SelectionChanged="OnProductPrintTemplateSelectionChanged" />
                    <Button x:Name="ChangeProductPrintTemplateButton" Margin="8,0,0,0" Click="OnChangeProductPrintTemplateClick" Content="更换模板" />
                    <Button x:Name="ProductPrintButton" Margin="8,0,0,0" Click="OnPrintSelectedSkusClick" Content="打印标签" Style="{StaticResource PrimaryButtonStyle}" />
                  </StackPanel>
                </DockPanel>
                <Grid Margin="0,0,0,14">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Grid Grid.ColumnSpan="4" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                      <Button x:Name="SkuModeButton" Click="OnSkuModeClick" Content="SKU" Style="{StaticResource PrimaryButtonStyle}" />
                      <Button x:Name="ProductModeButton" Margin="6,0,0,0" Click="OnProductModeClick" Content="产品" />
                    </StackPanel>
                    <TextBox x:Name="ProductQueryTextBox" Grid.Column="1" Height="36" Margin="18,0,12,0" VerticalContentAlignment="Center" ToolTip="输入编码、名称或规格" />
                    <Button x:Name="ProductQueryButton" Grid.Column="2" Click="OnQueryCurrentProductModeClick" Content="查询" Style="{StaticResource PrimaryButtonStyle}" />
                  </Grid>
                  <TextBox x:Name="ProductKeywordTextBox" Visibility="Collapsed" Grid.Column="0" ToolTip="产品编码或名称" />
                  <Button Visibility="Collapsed" Grid.Column="1" Margin="8,0,18,0" Click="OnSearchProductsClick" Content="查询产品" />
                  <TextBox x:Name="SkuKeywordTextBox" Visibility="Collapsed" Grid.Column="2" ToolTip="SKU编码或名称" />
                  <Button Visibility="Collapsed" Grid.Column="3" Margin="8,0,0,0" Click="OnSearchSkusClick" Content="查询 SKU" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <DataGrid x:Name="ProductsGrid" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Collapsed" Height="560" Margin="0" SelectionChanged="OnProductSelected" AutoGenerateColumns="False" GridLinesVisibility="None">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="产品编码" Binding="{Binding Code}" Width="140" />
                      <DataGridTextColumn Header="产品名称" Binding="{Binding Name}" Width="*" />
                      <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="110" />
                    </DataGrid.Columns>
                  </DataGrid>
                  <DataGrid x:Name="SkusGrid" Grid.Column="0" Grid.ColumnSpan="2" Height="560" Margin="0" AutoGenerateColumns="False" GridLinesVisibility="None">
                    <DataGrid.Columns>
                      <DataGridCheckBoxColumn Header="选择" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                      <DataGridTextColumn Header="SKU 编码" Binding="{Binding Code}" Width="180" />
                      <DataGridTextColumn Header="SKU 名称" Binding="{Binding Name}" Width="*" />
                      <DataGridTextColumn Header="规格" Binding="{Binding Spec}" Width="150" />
                      <DataGridTextColumn Header="产品" Binding="{Binding ProductCode}" Width="150" />
                    </DataGrid.Columns>
                  </DataGrid>
                </Grid>
                <DockPanel Margin="0,14,0,0">
                  <TextBlock x:Name="ProductStatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="等待查询中心数据" />
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="二维码前缀" />
                    <TextBox x:Name="SkuQrPrefixTextBox" Width="76" Margin="8,0,0,0" Text="T" />
                    <Button Margin="8,0,0,0" Click="OnSaveQrPrefixClick" Content="保存" />
                  </StackPanel>
                </DockPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="AdvancedPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="AdvancedContentStack" Margin="28">
            <Border Style="{StaticResource CardStyle}">
              <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="应用更新" />
                  <TextBlock x:Name="UpdateStatusText" Margin="0,6,16,0" Foreground="{StaticResource MutedTextBrush}" Text="启动后会自动检查 FSCM Edge 更新。" TextWrapping="Wrap" />
                </StackPanel>
                <Button x:Name="CheckForUpdatesButton" DockPanel.Dock="Right" VerticalAlignment="Center" Click="OnCheckForUpdatesClick" Content="检查更新" />
              </DockPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="后端服务控制" />
                <TextBlock Margin="0,6,0,16" Foreground="{StaticResource MutedTextBrush}" Text="这些操作会影响本地边缘服务，仅在排查或配置变更后使用。" />
                <StackPanel Orientation="Horizontal">
                  <Button Click="OnStartClick" Content="启动" Style="{StaticResource PrimaryButtonStyle}" />
                  <Button Margin="8,0,0,0" Click="OnStopClick" Content="停止" Style="{StaticResource DangerButtonStyle}" />
                  <Button Margin="8,0,0,0" Click="OnRestartClick" Content="重启" />
                  <Button Margin="8,0,0,0" Click="OnOpenRuntimeClick" Content="打开目录" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="180" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="中心打印任务领取" />
                  <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="边缘服务定期向中心领取待执行任务。保存后需要重启边缘服务生效。" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="领取周期（秒）" />
                  <TextBox x:Name="PrintPollIntervalTextBox" Margin="0,6,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Margin="12,27,0,0" Click="OnSavePrintPollIntervalClick" Content="保存" Style="{StaticResource PrimaryButtonStyle}" />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <UniformGrid Columns="2">
                <StackPanel Margin="0,0,18,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="端口" />
                  <TextBlock x:Name="AdvancedPortText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="进程 ID" />
                  <TextBlock x:Name="AdvancedProcessText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,18,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="二进制文件" />
                  <TextBlock x:Name="AdvancedBinaryText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="配置文件" />
                  <TextBlock x:Name="AdvancedConfigText" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,18,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="运行目录" />
                  <TextBlock x:Name="AdvancedRuntimePathText" Margin="0,5,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                  <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="日志目录" />
                  <TextBlock x:Name="AdvancedLogPathText" Margin="0,5,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
              </UniformGrid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,18,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="运行版本" />
                  <TextBlock x:Name="AdvancedVersionText" Margin="0,12,0,0" />
                  <TextBlock x:Name="AdvancedCommitText" Margin="0,8,0,0" TextWrapping="Wrap" />
                  <TextBlock x:Name="AdvancedApiText" Margin="0,8,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="日志文件" />
                  <Button Margin="0,12,0,0" HorizontalAlignment="Left" Click="OnOpenStdoutLogClick" Content="打开 stdout" />
                  <Button Margin="0,8,0,0" HorizontalAlignment="Left" Click="OnOpenStderrLogClick" Content="打开 stderr" />
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
