<Window
  x:Class="Fscm.Edge.Win.PrintPreviewWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="标签打印预览"
  Width="900"
  Height="680"
  MinWidth="720"
  MinHeight="560"
  WindowStartupLocation="CenterOwner"
  ResizeMode="CanResize">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#2563EB" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#2563EB" />
    </Style>
  </Window.Resources>

  <Grid Background="#F1F5F9">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="28,24,28,12">
      <TextBlock x:Name="PreviewTitleText" FontSize="22" FontWeight="SemiBold" Foreground="#0F172A" Text="标签打印预览" />
      <TextBlock x:Name="PreviewDescriptionText" Margin="0,6,0,0" Foreground="#64748B" />
    </StackPanel>

    <Border Grid.Row="1" Margin="28,0" Background="White" BorderBrush="#CBD5E1" BorderThickness="1">
      <DocumentViewer x:Name="PreviewViewer" Background="#E2E8F0" />
    </Border>

    <DockPanel Grid.Row="2" Margin="28,12,28,24">
      <TextBlock x:Name="PreviewHintText" VerticalAlignment="Center" Foreground="#64748B" TextWrapping="Wrap" />
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button x:Name="CancelButton" Click="OnCancelClick" Content="返回修改" />
        <Button x:Name="ConfirmPrintButton" Margin="10,0,0,0" Click="OnConfirmPrintClick" Content="确认打印" Style="{StaticResource PrimaryButtonStyle}" />
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
